# conexión a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nombre_de_tu_base
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# tablas que la IA puede consultar (nombres reales en la DB, separar con coma)
ALLOWED_TABLES=tabla1,tabla2

# palabras clave por tabla para detectar cuál consultar según la pregunta
TABLE_DESCRIPTIONS=

# aliases: si el usuario dice "alumno" pero la tabla se llama "ist_alumno"
TABLE_ALIASES=

# proveedor de IA activo
AI_PROVIDER=claude

# modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-6

# máximo de tokens en la respuesta de la IA
AI_MAX_TOKENS=4096

# guardar respuestas en cache para no repetir consultas iguales
CACHE_ENABLED=false

# tiempo de vida del cache en horas
CACHE_TTL_HOURS=24

# activar solo si hay un reverse proxy (nginx) que setea X-Forwarded-For
TRUST_PROXY=false

# máximo de IPs distintas en memoria para el rate limiter
RATE_LIMIT_MAX_IPS=10000

# máximo de caracteres permitidos en la pregunta
MAX_QUESTION_LENGTH=2000

# tamaño máximo del body en bytes (1048576 = 1MB)
MAX_BODY_SIZE=1048576

# orígenes CORS permitidos separados por coma (vacío = todos)
CORS_ORIGINS=
