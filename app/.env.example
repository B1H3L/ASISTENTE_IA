# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nombre_de_tu_base
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# ── Tablas permitidas (nombres reales en la DB, separar con coma) ──
ALLOWED_TABLES=tabla1,tabla2

# ── Descripciones de tablas (deteccion semantica por palabras clave) ──
# Formato: tabla_real:palabra1 palabra2 sinonimo;otra_tabla:palabra3
# Ejemplo: TABLE_DESCRIPTIONS=ist_alumno:alumno alumnos estudiante;ist_persona:persona nombre apellido
TABLE_DESCRIPTIONS=

# ── Aliases nombre_natural:nombre_real_en_db ──────────────────
# Ejemplo: TABLE_ALIASES=alumno:ist_alumno,persona:ist_persona
TABLE_ALIASES=

# ── Proveedor de IA por defecto: ollama | claude | gpt | github ──
AI_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────
AI_API_URL=http://localhost:11434
AI_MODEL=llama3.2:1b

# ── Claude (Anthropic) ────────────────────────────────────────
ANTHROPIC_API_KEY=tu_api_key_de_anthropic
CLAUDE_MODEL=claude-sonnet-4-6

# ── GitHub Models (GPT-4o mini, gratis con GitHub PAT) ───────
GITHUB_TOKEN=tu_github_personal_access_token
GITHUB_GPT_MODEL=gpt-4o-mini

# ── Limites ───────────────────────────────────────────────────
AI_MAX_TOKENS=4096

# ── Cache de respuestas en PostgreSQL ─────────────────────────
CACHE_ENABLED=true
CACHE_TTL_HOURS=24
